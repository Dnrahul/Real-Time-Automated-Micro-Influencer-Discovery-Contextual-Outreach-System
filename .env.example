# ========================================
# 🔑 API Keys
# ========================================

# YouTube Data API v3 Key (Required)
# Get yours at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# OpenAI API Key (Optional — for advanced outreach generation)
OPENAI_API_KEY=your_openai_api_key_here

# ========================================
# 📧 Email Configuration (SMTP)
# ========================================

# Gmail SMTP (enable "App Passwords" in Google Account)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_NAME=BrandOutreach Team

# ========================================
# 📱 Instagram Configuration (Optional)
# ========================================

# Instagram credentials (for Instagrapi-based DM automation)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# ========================================
# ⚙️ Application Settings
# ========================================

# Filtering thresholds
MIN_FOLLOWERS=5000
MAX_FOLLOWERS=100000
MIN_ENGAGEMENT_RATE=1.0
TARGET_COUNTRY=IN

# Scoring weights (must sum to 1.0)
WEIGHT_ENGAGEMENT=0.30
WEIGHT_RELEVANCE=0.35
WEIGHT_FOLLOWERS=0.15
WEIGHT_ACTIVITY=0.20

# Discovery limits
MAX_RESULTS_PER_PLATFORM=50
DAYS_SINCE_LAST_ACTIVE=30

# ========================================
# 🔧 Debug / Development
# ========================================
DEBUG=true
USE_MOCK_DATA=true
